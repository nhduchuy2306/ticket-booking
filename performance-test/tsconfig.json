{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "k6": ["types/k6-shim"],
      "k6/http": ["types/k6-http-shim"]
    }
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}

