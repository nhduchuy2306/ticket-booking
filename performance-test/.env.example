# Base URL of the API Gateway (default route entrypoint)
BASE_URL=http://localhost:9999

# Optional fallback event id if the on-sale list cannot be parsed
EVENT_ID=

# Auto auth flow against auth-service (customer login)
AUTH_ENABLED=true
AUTH_LOGIN_EMAIL=
AUTH_LOGIN_PASSWORD=
AUTH_LOGIN_PATH=/auths/customer/auth/login
AUTH_REFRESH_PATH=/auths/customer/auth/refresh-token
AUTH_REFRESH_THRESHOLD_SECONDS=30

# Optional bearer token fallback if you want to bypass login
AUTH_TOKEN=
AUTH_HEADER=Authorization

# Think time between iterations (seconds)
THINK_TIME=1

# Whether to also browse /events/coming-events after the on-sale list and detail page
BROWSE_COMING_EVENTS=true

# TLS safety toggle for non-local environments
INSECURE_SKIP_TLS_VERIFY=false

